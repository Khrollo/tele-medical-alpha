# ————————————————————————————————————————————————
# tele-medical — environment template
# Copy to .env.local and fill in values for local development.
# ————————————————————————————————————————————————

# ——— Supabase ————————————————————————————————————
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ——— Database ————————————————————————————————————
# Pooler URL (port 6543) is preferred for serverless runtime.
# Direct-connection URL (port 5432) is commented for reference.
DATABASE_URL=
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ——— Twilio (video + messaging) ————————————————
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ——— Auth ————————————————————————————————————————
JWT_SECRET=
NEW_USER_PWD=

# ——— AI providers ——————————————————————————————
# Async / offline transcription via Replicate Whisper.
REPLICATE_API_KEY=

# Real-time visit-note parsing. At least one of ANTHROPIC_API_KEY or
# OPENROUTER_API_KEY must be set; see the AI_PROVIDER selection below.
#
# Claude Haiku 4.5 via the Anthropic SDK. Preferred — lower latency, prompt
# caching, pay-as-you-go without the free-tier daily cap. Requires a BAA
# with Anthropic for real PHI.
ANTHROPIC_API_KEY=

# OpenRouter fallback. Used when ANTHROPIC_API_KEY is unset, or when
# AI_PROVIDER=openrouter is explicit. Free tier has a 50 req/day cap.
OPENROUTER_API_KEY=

# Explicit provider override. Resolution order when this is unset:
#   1. ANTHROPIC_API_KEY present → anthropic
#   2. OPENROUTER_API_KEY present → openrouter
#   3. default → anthropic (surfaces a clear "missing API key" error)
# AI_PROVIDER=anthropic

# ——— Live transcription (Deepgram, optional) ——
# When configured, the calibrated live-visit screen can route real-time
# speech-to-text through Deepgram for better accuracy + built-in speaker
# diarization. Defaults to browser Web Speech API when these are empty.
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=
# NEXT_PUBLIC_STT_PROVIDER=deepgram

# ——— App ————————————————————————————————————————
NEXT_PUBLIC_APP_URL=http://localhost:3000
